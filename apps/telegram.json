{
  "app": "Telegram",
  "process_name": "Telegram",
  "layout": {
    "sidebar_width": 300,
    "sidebar_x_max": 400,
    "input_bottom_offset": 50
  },
  "navigation": {
    "method": "sidebar_click",
    "fallback": "search",
    "search_shortcut": {"key": "f", "modifiers": ["command"]}
  },
  "input": {
    "method": "ocr",
    "ocr_keyword": "Write a message",
    "fallback": "window_calc"
  },
  "send": {
    "key": "return"
  },
  "verify": {
    "method": "ocr",
    "region": "main_area"
  },
  "quirks": [
    "Search with Cmd+F works well",
    "Enter sends by default (configurable)"
  ]
}
