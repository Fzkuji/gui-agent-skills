{
  "app": "Discord",
  "process_name": "Discord",
  "layout": {
    "server_list_width": 72,
    "channel_sidebar_width": 240,
    "sidebar_x_max": 312,
    "input_bottom_offset": 60
  },
  "navigation": {
    "method": "sidebar_click",
    "fallback": "search",
    "search_shortcut": {"key": "k", "modifiers": ["command"]}
  },
  "input": {
    "method": "window_calc",
    "fallback": "ocr",
    "ocr_keyword": "Message #"
  },
  "send": {
    "key": "return"
  },
  "verify": {
    "method": "ocr",
    "region": "main_area"
  },
  "quirks": [
    "Accessibility API excellent (1362 elements)",
    "Cmd+K opens quick switcher for channels/DMs",
    "Shift+Enter for newline, Enter sends"
  ]
}
