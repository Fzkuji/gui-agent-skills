{
  "app": "WeChat",
  "process_name": "WeChat",
  "layout": {
    "sidebar_width": 250,
    "input_bottom_offset": 80,
    "sidebar_x_max": 430
  },
  "navigation": {
    "method": "sidebar_click",
    "fallback": "search",
    "search_bar": {"template": "search_bar"},
    "search_result_filter": {
      "skip_y_max": 220,
      "skip_prefix": ["Q "]
    }
  },
  "input": {
    "method": "window_calc",
    "note": "OCR can't see placeholder text, use window position calc"
  },
  "send": {
    "key": "return",
    "note": "Enter sends, not Cmd+Enter"
  },
  "verify": {
    "method": "ocr",
    "region": "main_area"
  },
  "quirks": [
    "Clicking already-selected chat doesn't reopen it — click another first",
    "Cmd+F opens web search not contact search",
    "Accessibility API useless (5 elements)",
    "Input placeholder too faint for OCR"
  ]
}
